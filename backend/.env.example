# Core
JWT_SECRET=change-this-to-a-secure-secret
PORT=3001
NODE_ENV=development

# Supabase - Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ================================================
# Email provider (pick ONE — first match wins)
# Priority: Gmail > SMTP > Resend > console
# ================================================

# --- Option 1: Gmail SMTP ---
# GMAIL_USER=your-gmail@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password

# --- Option 2: Generic SMTP (Brevo, SendGrid, Mailgun) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
EMAIL_FROM=CampusGig <noreply@yourdomain.com>

# --- Option 3: Resend ---
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM=CampusGig <onboarding@resend.dev>
